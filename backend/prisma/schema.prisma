// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ExamMode {
  PRACTICE
  STANDARD
  THPTQG
}

enum DurationUnit {
  MINUTE
  HOUR
  DAY
  WEEK
  MONTH
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          Role      @default(STUDENT) // Quyền tối đa
  activeRole    Role      @default(STUDENT) // Chế độ UI hiện tại (Teacher / Student)
  
  authId        String?   @unique // ID từ Supabase Auth
  oauthProvider String?   // 'google', 'email'...
  
  // Relations
  createdExams  Exam[]    @relation("TeacherExams")
  enrollments   Enrollment[]
  submissions   Submission[]
  files         UploadedFile[]
  
  createdAt     DateTime  @default(now())
}

model Class {
  id          String       @id @default(uuid())
  name        String
  teacherId   String
  
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
}

// Junction Table: Many-to-Many giữa User và Class
model Enrollment {
  userId      String
  classId     String
  user        User     @relation(fields: [userId], references: [id])
  class       Class    @relation(fields: [classId], references: [id])

  @@id([userId, classId])
}

model Exam {
  id          String      @id @default(uuid())
  title       String
  description String?
  teacherId   String
  teacher     User        @relation("TeacherExams", fields: [teacherId], references: [id])
  
  isTimed     Boolean     @default(true)
  durationValue Int?      // Giá trị số
  durationUnit  DurationUnit? @default(MINUTE) // Đơn vị thời gian
  
  startTime   DateTime?
  endTime     DateTime?
  status      ExamStatus  @default(DRAFT)

  // New Settings
  mode               ExamMode @default(STANDARD)
  strictMode         Boolean  @default(false)
  fullscreenRequired Boolean  @default(false)
  maxAttempts        Int      @default(0) // 0 = unlimited
  shuffleQuestions   Boolean  @default(false)
  shuffleOptions     Boolean  @default(false)
  examCode           String?

  // Result & Scoring Settings
  allowAnswerReview  Boolean  @default(true)
  allowScoreView     Boolean  @default(true)
  maxScore           Float    @default(10.0)

  // Password Protection
  requiresPassword   Boolean  @default(false)
  passwordHash       String?
  
  // Access Control & Security
  requireLogin       Boolean  @default(false)
  publicId           String   @unique @default(dbgenerated("gen_random_uuid()"))
  
  questions   Question[]
  submissions Submission[]
  
  createdAt   DateTime    @default(now())
}

model Question {
  id          String    @id @default(uuid())
  examId      String
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  type        String    // MULTIPLE_CHOICE, TRUE_FALSE, TRUE_FALSE_GROUP, ESSAY
  content     String    // Markdown text
  points      Float     @default(1.0)
  explanation String?   // Markdown explanation
  
  // metadata chứa JSON structure cho các type cũ hoặc bổ trợ
  metadata    Json      
  
  statements  TrueFalseStatement[]
  answers     SubmissionAnswer[]
}

model TrueFalseStatement {
  id            String    @id @default(uuid())
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content       String    // Nội dung mệnh đề (Markdown)
  correctAnswer Boolean   // Đúng hoặc Sai
  order         Int       @default(0)
}

model Submission {
  id          String    @id @default(uuid())
  examId      String
  userId      String?
  exam        Exam      @relation(fields: [examId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
  
  // Guest fields
  guestName       String?
  guestSessionId  String?
  
  startTime   DateTime  @default(now())
  endTime     DateTime?
  status      String    // IN_PROGRESS, SUBMITTED
  score       Float?

  // THPTQG Info
  candidateNumber  String?
  examCode         String?

  // Tracking
  attemptNumber    Int      @default(1)
  violations       Json     @default("[]") // List of violation events
  deviceIdentifier String?  // Browser fingerprint or similar
  
  // Display settings at time of submission
  scoreHidden      Boolean  @default(false)
  reviewHidden     Boolean  @default(false)

  answers     SubmissionAnswer[]
  
  @@unique([examId, userId, attemptNumber]) // Allow multiple attempts
}

model SubmissionAnswer {
  id           String     @id @default(uuid())
  submissionId String
  questionId   String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id])
  
  studentAnswer Json?     // Lựa chọn của học sinh
  isCorrect    Boolean?
  pointsAwarded Float?

  @@unique([submissionId, questionId])
}

model UploadedFile {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  
  fileUrl     String
  status      String    // PENDING, PROCESSING, DONE, FAILED
  rawText     String?   @db.Text
  parsedJson  Json?
  
  createdAt   DateTime  @default(now())
}
